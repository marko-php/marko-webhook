{
    "name": "marko/webhook",
    "description": "Webhook sending package for Marko Framework",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "marko/core": "self.version",
        "marko/routing": "self.version",
        "marko/http": "self.version",
        "marko/queue": "self.version",
        "marko/config": "self.version"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "marko/testing": "self.version"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Webhook\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Webhook\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
